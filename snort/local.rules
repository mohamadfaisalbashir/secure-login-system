# Deteksi ICMP Flood (Ping of Death / DoS)
# Jika ada lebih dari 20 ping dalam 10 detik dari IP yang sama, bunyikan alert.
alert icmp any any -> $HOME_NET any (msg:"[RULE LOKAL] Terdeteksi ICMP Flood - Potensi DoS!"; itype:8; detection_filter:track by_src, count 20, seconds 10; sid:1000001; rev:1;)

# Deteksi akses ke endpoint register yang mencurigakan (Contoh tambahan)
alert tcp any any -> $HOME_NET 8080 (msg:"[RULE LOKAL] Percobaan akses API Register"; content:"POST"; content:"/api/register"; sid:1000002; rev:1;)